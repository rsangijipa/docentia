// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  role      String   @default("TEACHER") // TEACHER, COORDINATOR, ADMIN
  profile   Profile?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  notifications Notification[]
  lessons       LessonPlan[]
  turmas        ClassRoom[] @relation("TeacherClasses")
}

model Profile {
  id           String   @id @default(uuid())
  userId       String   @unique
  user         User     @relation(fields: [userId], references: [id])
  avatar       String?
  phone        String?
  specialty    String?
  education    String?
  schoolId     String?
  school       School?  @relation(fields: [schoolId], references: [id])
}

model School {
  id        String   @id @default(uuid())
  name      String
  address   String?
  type      String   @default("municipal")
  logo      String?
  color     String?
  
  profiles  Profile[]
  years     SchoolYear[]
  subjects  Subject[]
  turmas    ClassRoom[]
  textbooks Textbook[]
  projects  PedagogicalProject[]
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SchoolYear {
  id        String   @id @default(uuid())
  name      String
  startDate DateTime
  endDate   DateTime
  active    Boolean  @default(false)
  schoolId  String
  school    School   @relation(fields: [schoolId], references: [id])
  
  coursePlans CoursePlan[]
}

model Subject {
  id        String   @id @default(uuid())
  name      String
  schoolId  String
  school    School   @relation(fields: [schoolId], references: [id])
  
  turmas    ClassRoom[]
}

model ClassRoom {
  id        String   @id @default(uuid())
  nome      String
  serie     String
  turno     String   @default("matutino")
  schoolId  String
  school    School   @relation(fields: [schoolId], references: [id])
  subjectId String
  subject   Subject  @relation(fields: [subjectId], references: [id])
  teacherId String
  teacher   User     @relation("TeacherClasses", fields: [teacherId], references: [id])
  
  alunos    Student[]
  coursePlans CoursePlan[]
  diaries     ClassDiaryEntry[]
  attendance  AttendanceRecord[]
  evaluations Evaluation[]
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Student {
  id              String   @id @default(uuid())
  nome            String
  matricula       String   @unique
  turmaId         String
  turma           ClassRoom @relation(fields: [turmaId], references: [id])
  frequenciaGeral Float    @default(0)
  desempenhoGeral Float    @default(0)
  status          String   @default("ativo")
  observacoes     String?
  
  attendance      AttendanceItem[]
  textbookProgress TextbookProgress[]
  evaluationResults EvaluationResult[]
}

model CoursePlan {
  id          String   @id @default(uuid())
  title       String
  goals       String?
  methodology String?
  assessment  String?
  roomId      String
  room        ClassRoom @relation(fields: [roomId], references: [id])
  yearId      String
  year        SchoolYear @relation(fields: [yearId], references: [id])
  
  units       CoursePlanUnit[]
  lessons     LessonPlan[]
}

model CoursePlanUnit {
  id          String   @id @default(uuid())
  title       String
  goals       String?
  context     String?
  planId      String
  plan        CoursePlan @relation(fields: [planId], references: [id])
}

model LessonPlan {
  id          String   @id @default(uuid())
  date        DateTime
  topic       String
  content     String?
  goals       String?
  methodology String?
  assessment  String?
  resources   String?
  status      String   @default("planejado") // planejado, realizado, cancelado
  
  coursePlanId String
  coursePlan   CoursePlan @relation(fields: [coursePlanId], references: [id])
  teacherId    String
  teacher      User       @relation(fields: [teacherId], references: [id])
  
  resourceItems LessonPlanResource[]
}

model LessonPlanResource {
  id          String   @id @default(uuid())
  title       String
  type        String   @default("link") // link, file, book_page
  url         String?
  lessonId    String
  lessonPlan  LessonPlan @relation(fields: [lessonId], references: [id])
}

model CalendarEvent {
  id          String   @id @default(uuid())
  title       String
  date        DateTime
  type        String   @default("academic") // academic, meeting, holiday, training
  priority    String   @default("medium")
  description String?
  schoolId    String? // Could be global to school
  roomId      String? // Or specific to room
  
  createdAt DateTime @default(now())
}

model AttendanceRecord {
  id        String   @id @default(uuid())
  date      DateTime
  roomId    String
  room      ClassRoom @relation(fields: [roomId], references: [id])
  
  items     AttendanceItem[]
}

model AttendanceItem {
  id          String   @id @default(uuid())
  studentId   String
  student     Student  @relation(fields: [studentId], references: [id])
  recordId    String
  record      AttendanceRecord @relation(fields: [recordId], references: [id])
  present     Boolean  @default(true)
}

model ClassDiaryEntry {
  id        String   @id @default(uuid())
  date      DateTime
  content   String
  observations String?
  roomId    String
  room      ClassRoom @relation(fields: [roomId], references: [id])
}

model Textbook {
  id        String   @id @default(uuid())
  title     String
  schoolId  String
  school    School   @relation(fields: [schoolId], references: [id])
  
  chapters  TextbookChapter[]
}

model TextbookChapter {
  id          String   @id @default(uuid())
  title       String
  textbookId  String
  textbook    Textbook @relation(fields: [textbookId], references: [id])
  
  progress    TextbookProgress[]
}

model TextbookProgress {
  id          String   @id @default(uuid())
  studentId   String
  student     Student  @relation(fields: [studentId], references: [id])
  chapterId   String
  chapter     TextbookChapter @relation(fields: [chapterId], references: [id])
  status      String   @default("não iniciado") // não iniciado, em progresso, concluído
}

model PedagogicalProject {
  id          String   @id @default(uuid())
  title       String
  goals       String?
  schoolId    String
  school      School   @relation(fields: [schoolId], references: [id])
  status      String   @default("em planejamento")
  
  steps       ProjectStep[]
}

model ProjectStep {
  id          String   @id @default(uuid())
  title       String
  description String?
  status      String   @default("pendente")
  projectId   String
  project     PedagogicalProject @relation(fields: [projectId], references: [id])
}

model Evaluation {
  id          String   @id @default(uuid())
  type        String   @default("prova") // prova, trabalho, seminario
  date        DateTime
  weight      Float    @default(1.0)
  roomId      String
  room        ClassRoom @relation(fields: [roomId], references: [id])
  
  results     EvaluationResult[]
}

model EvaluationResult {
  id            String   @id @default(uuid())
  studentId     String
  student       Student  @relation(fields: [studentId], references: [id])
  evaluationId  String
  evaluation    Evaluation @relation(fields: [evaluationId], references: [id])
  grade         Float?
}

model Notification {
  id        String   @id @default(uuid())
  title     String
  message   String
  read      Boolean  @default(false)
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
}

model GeneratedReport {
  id        String   @id @default(uuid())
  title     String
  type      String
  url       String
  metadata  String? // JSON metadata
  createdAt DateTime @default(now())
}

model Setting {
  id    String @id @default(uuid())
  key   String @unique
  value String
}
